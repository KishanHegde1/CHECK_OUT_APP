# Application
APP_NAME=Hostel Checkout API
APP_ENV=development
DEBUG=false
API_PREFIX=/api

# PostgreSQL / Neon. Percent-encode reserved URL characters in credentials.
DATABASE_URL=postgresql+psycopg://username:replace_me@localhost:5432/database_name?sslmode=require
DATABASE_CONNECT_TIMEOUT_SECONDS=10

# Generate a unique value for each environment. Never use this placeholder in production.
SECRET_KEY=replace-with-a-long-random-secret-generated-for-this-environment
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Use the exact Flutter Web origin in production. Native Flutter clients do not use CORS.
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
